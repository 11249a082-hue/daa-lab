#include <stdio.h>

int main() {
    int items[100], bins[100];
    int n, capacity;

    printf("Enter number of items: ");
    scanf("%d", &n);

    printf("Enter bin capacity: ");
    scanf("%d", &capacity);

    printf("Enter item sizes:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &items[i]);
    }

    int binCount = 0;

    // First Fit algorithm
    for (int i = 0; i < n; i++) {
        int placed = 0;

        for (int j = 0; j < binCount; j++) {
            if (bins[j] + items[i] <= capacity) {
                bins[j] += items[i];
                placed = 1;
                break;
            }
        }

        if (!placed) {
            bins[binCount] = items[i];
            binCount++;
        }
    }

    printf("\nNumber of bins used = %d\n", binCount);

    return 0;
}
