#include <stdio.h>

// Recursive Fibonacci
int fibRecursive(int n) {
    if (n == 0)
        return 0;
    if (n == 1)
        return 1;

    return fibRecursive(n - 1) + fibRecursive(n - 2);
}

// Iterative Fibonacci
int fibIterative(int n) {
    if (n == 0)
        return 0;
    if (n == 1)
        return 1;

    int a = 0, b = 1, c;

    for (int i = 2; i <= n; i++) {
        c = a + b;
        a = b;
        b = c;
    }

    return b;
}

int main() {
    int n;

    printf("Enter value of n: ");
    scanf("%d", &n);

    printf("\nFibonacci (Recursive) = %d\n", fibRecursive(n));
    printf("Fibonacci (Iterative) = %d\n", fibIterative(n));

    return 0;
}
