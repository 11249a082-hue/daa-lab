#include <stdio.h>
#include <limits.h>

#define N 4

int min(int a, int b) {
    return (a < b) ? a : b;
}

// Function to find minimum cost using recursion
int tsp(int graph[N][N], int visited[], int currPos, int count, int cost, int ans) {
    
    // If all cities visited, return cost to starting city
    if (count == N && graph[currPos][0]) {
        return min(ans, cost + graph[currPos][0]);
    }

    // Try all unvisited cities
    for (int i = 0; i < N; i++) {
        if (!visited[i] && graph[currPos][i]) {
            visited[i] = 1;

            ans = tsp(graph, visited, i, count + 1,
                      cost + graph[currPos][i], ans);

            visited[i] = 0; // backtrack
        }
    }

    return ans;
}

int main() {
    int graph[N][N] = {
        {0, 10, 15, 20},
        {10, 0, 35, 25},
        {15, 35, 0, 30},
        {20, 25, 30, 0}
    };

    int visited[N] = {0};

    visited[0] = 1; // start from city 0

    int result = tsp(graph, visited, 0, 1, 0, INT_MAX);

    printf("Minimum travelling cost = %d\n", result);

    return 0;
}
